# 로컬 환경 오버라이드 예시.
# 이 파일을 .env로 복사해서 쓴다. .env는 gitignore 대상이다.
#
#   cp .env.example .env
#
# 값을 바꾸는 건 "호스트 포트"뿐이다. 컨테이너끼리는 항상 기본 포트로
# 통신하므로(mysql:3306, rabbitmq:5672 등) 서비스 설정은 건드릴 필요 없다.

# ── 호스트 포트 충돌 회피 ────────────────────────────────
# 호스트에 이미 MySQL/MongoDB가 설치돼 있으면 여기서 바꾼다.
# 확인: Get-NetTCPConnection -LocalPort 3306 -State Listen
#MYSQL_PORT=3307
#MONGO_PORT=27018
#MINIO_PORT=9000
#MINIO_CONSOLE_PORT=9001
#RABBITMQ_PORT=5672
#RABBITMQ_UI_PORT=15672

# ── 자격증명 ──────────────────────────────────────────
# 로컬 개발용 기본값이 compose에 박혀 있다. 운영에서는 반드시 바꾼다.
#MYSQL_ROOT_PASSWORD=root
#MINIO_ROOT_USER=minioadmin
#MINIO_ROOT_PASSWORD=minioadmin
#RABBITMQ_USER=lxp
#RABBITMQ_PASSWORD=lxp

# ── 정기 결제 데모 ────────────────────────────────────
# 주기를 0일로 두면 다음 폴링에서 바로 다음 회차가 청구된다.
#BILLING_PERIOD_DAYS=0
#BILLING_SCHEDULER_INTERVAL_MS=10000
