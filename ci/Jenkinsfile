// LXP MSA 빌드 파이프라인
//
// 모노레포지만 각 서비스가 독립 Gradle 프로젝트라, 변경된 서비스만 골라 빌드한다.
// 서비스 7개를 매번 전부 빌드하면 한 줄 고쳐도 10분 넘게 기다리게 된다.
//
// 로컬 Jenkins는 공인 IP가 없어 GitHub webhook을 받을 수 없다.
// 그래서 pollSCM으로 시작한다. (docs/NEXT_STEPS.md Step 3)

pipeline {
    agent any

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 30, unit: 'MINUTES')
    }

    triggers {
        // 평소 경로: GitHub webhook 수신 시 즉시 빌드 (D-47).
        githubPush()

        // 안전망: 4시간마다 폴링 (D-51).
        //
        // webhook은 GitHub가 우리를 찾아올 수 있어야 성립한다. cloudflared
        // 터널이 끊기면 GitHub는 배달에 실패하고 우리 쪽은 아무 일도 일어나지
        // 않는다 — 에러도 나지 않고 그냥 조용히 멈춘다.
        //
        // 실제로 겪었다. 터널 창이 닫힌 줄 모르고 PR을 머지했는데 빌드가
        // 영영 뜨지 않았다. 커밋은 main에 들어가 있는데 아무도 빌드하지 않은
        // 상태가 그대로 남았다.
        //
        // 4시간인 이유 — webhook이 정상이면 폴링은 "변경 없음"만 확인하고
        // 지나가므로 짧게 잡을 이유가 없다. 터널이 죽었을 때 하루가 아니라
        // 반나절 안에는 잡히게 하는 것이 목적이다.
        //
        // D-47에서 폴링을 일부러 껐던 이유(빌드가 webhook 때문인지 폴링
        // 때문인지 구분)는 이미 확인이 끝나 더 유효하지 않다.
        // 콘솔의 "Started by" 줄로 여전히 구분된다.
        pollSCM('H H/4 * * *')
    }

    environment {
        // auth-service는 member-service에 흡수됐다(D-04). 목록에 남겨두면
        // "전체 빌드" 경로에서 dir('auth-service')가 없는 디렉터리를 열어 파이프라인이 죽는다.
        SERVICES = 'gateway config-server member-service course-service subscription-service payment-service'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    // checkout이 돌려주는 값에서 브랜치를 직접 꺼낸다.
                    //
                    // when { branch 'main' }을 쓰지 않는 이유 — 그 조건은 BRANCH_NAME을 보는데,
                    // BRANCH_NAME은 멀티브랜치 파이프라인에서만 채워진다. 단일 브랜치 잡에서는
                    // 비어 있어서 조건이 영영 참이 되지 않고, 이미지 빌드 단계가 조용히 건너뛰어진다.
                    // 실제로 그렇게 돌고 있었다(빌드 #2에서 "skipped due to when conditional").
                    def scmVars = checkout scm
                    env.GIT_SHORT = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    // 단일 브랜치 잡에서는 "origin/main", 멀티브랜치에서는 "main"으로 온다.
                    env.BUILT_BRANCH = (scmVars.GIT_BRANCH ?: '').replaceFirst(/^origin\//, '')
                }
                echo "빌드 대상 커밋: ${env.GIT_SHORT} (브랜치: ${env.BUILT_BRANCH ?: '알 수 없음'})"
            }
        }

        stage('변경 서비스 탐지') {
            steps {
                script {
                    // 이전 성공 커밋과 비교. 첫 빌드거나 기준을 찾지 못하면 전체를 빌드한다.
                    def base = sh(
                        script: 'git rev-parse HEAD~1 2>/dev/null || echo ""',
                        returnStdout: true
                    ).trim()

                    def changed = []
                    if (base) {
                        def diff = sh(
                            script: "git diff --name-only ${base} HEAD",
                            returnStdout: true
                        ).trim()

                        // 공용 파일이 바뀌면 어느 서비스가 영향받는지 알 수 없으므로 전체 빌드.
                        //
                        // common-* 모듈은 서비스들이 컴파일 타임에 링크한다(D-30·D-33).
                        // 여기 없으면 공통 모듈만 고친 커밋이 "변경 서비스 없음"으로 잡혀
                        // 아무것도 빌드하지 않고 통과한다 — 깨졌는지 알 수 없다.
                        //
                        // 접두사를 하나씩 나열하지 않고 common-으로 묶는다.
                        // 모듈이 늘 때마다 여기를 고치는 것을 잊으면 같은 구멍이 다시 생긴다.
                        //
                        // ci/도 공용이다 (D-49). ci/Dockerfile은 모든 서비스가 빌드되는
                        // 환경이고 ci/Jenkinsfile은 빌드 방법 자체다. 여기 없으면
                        // 빌드 환경을 깨는 변경이 "변경 서비스 없음"으로 통과한다.
                        //
                        // 실제로 그랬다 — jdk17에서 jdk21로 올린 커밋(D-46)이
                        // 6개 서비스의 Gradle toolchain을 전부 깨뜨렸는데,
                        // 그 수정 커밋(D-48)은 ci/Dockerfile만 건드려서 빌드 #11이
                        // 아무것도 빌드하지 않고 SUCCESS로 끝났다.
                        // D-38이 common-security를 빠뜨렸던 것과 같은 종류다.
                        def sharedTouched = diff.split('\n').any { path ->
                            path.startsWith('config-repo/') ||
                            path.startsWith('common-') ||
                            path.startsWith('infrastructure/') ||
                            path.startsWith('ci/') ||
                            path.startsWith('compose') ||
                            path == '.gitattributes'
                        }

                        if (sharedTouched) {
                            echo '공용 설정 변경 감지 — 전체 빌드'
                            changed = env.SERVICES.split(' ')
                        } else {
                            changed = env.SERVICES.split(' ').findAll { svc ->
                                diff.split('\n').any { it.startsWith("${svc}/") }
                            }
                        }
                    } else {
                        echo '비교 기준 없음 — 전체 빌드'
                        changed = env.SERVICES.split(' ')
                    }

                    env.CHANGED_SERVICES = changed.join(' ')
                    echo "빌드 대상: ${env.CHANGED_SERVICES ?: '없음'}"
                }
            }
        }

        stage('빌드 · 테스트') {
            when {
                expression { env.CHANGED_SERVICES?.trim() }
            }
            steps {
                script {
                    env.CHANGED_SERVICES.split(' ').each { svc ->
                        stage("build:${svc}") {
                            dir(svc) {
                                sh './gradlew clean build --no-daemon'
                            }
                        }
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: '*/build/test-results/test/*.xml'
                }
            }
        }

        stage('Docker 이미지 빌드') {
            when {
                allOf {
                    expression { env.CHANGED_SERVICES?.trim() }
                    // Checkout 단계가 채운 값을 본다. branch 'main'은 단일 브랜치 잡에서
                    // 절대 참이 되지 않아 이 단계가 조용히 건너뛰어진다.
                    expression { env.BUILT_BRANCH == 'main' }
                }
            }
            steps {
                script {
                    env.CHANGED_SERVICES.split(' ').each { svc ->
                        // Dockerfile이 루트 컨텍스트를 전제로 하므로 -f 로 지정한다.
                        //
                        // 레지스트리 주소를 태그에 함께 붙인다 (D-50).
                        // docker push는 태그의 앞부분을 레지스트리 주소로 읽으므로,
                        // 주소 없는 태그(lxp/gateway)는 Docker Hub로 가려 한다.
                        sh """
                            docker build -f ${svc}/Dockerfile \
                                -t lxp/${svc}:${env.GIT_SHORT} \
                                -t lxp/${svc}:latest \
                                -t ${env.REGISTRY_HOST}/lxp/${svc}:${env.GIT_SHORT} \
                                -t ${env.REGISTRY_HOST}/lxp/${svc}:latest .
                        """
                    }
                }
            }
        }

        stage('Docker 이미지 푸시') {
            when {
                allOf {
                    expression { env.CHANGED_SERVICES?.trim() }
                    expression { env.BUILT_BRANCH == 'main' }
                }
            }
            steps {
                // 자격증명은 Jenkins가 주입한다 (D-50). 파이프라인은 id만 알고
                // 실제 값은 모른다 — 저장소에도 콘솔 로그에도 남지 않는다.
                // Jenkins가 로그에서 이 값들을 자동으로 마스킹한다.
                withCredentials([usernamePassword(
                        credentialsId: 'registry-credentials',
                        usernameVariable: 'REG_USER',
                        passwordVariable: 'REG_PASS')]) {
                    script {
                        // --password-stdin을 쓴다. -p는 비밀번호가 프로세스 목록에
                        // 노출되고 docker가 경고를 낸다.
                        sh '''
                            echo "$REG_PASS" | docker login "$REGISTRY_HOST" -u "$REG_USER" --password-stdin
                        '''
                        try {
                            env.CHANGED_SERVICES.split(' ').each { svc ->
                                sh "docker push ${env.REGISTRY_HOST}/lxp/${svc}:${env.GIT_SHORT}"
                                sh "docker push ${env.REGISTRY_HOST}/lxp/${svc}:latest"
                            }
                        } finally {
                            // 실패해도 반드시 로그아웃한다. 남겨두면 다음 빌드가
                            // 이전 빌드의 자격증명으로 돌 수 있다.
                            sh 'docker logout "$REGISTRY_HOST" || true'
                        }
                    }
                }
            }
        }

        stage('배포') {
            when {
                allOf {
                    expression { env.CHANGED_SERVICES?.trim() }
                    expression { env.BUILT_BRANCH == 'main' }
                }
            }
            steps {
                withCredentials([usernamePassword(
                        credentialsId: 'registry-credentials',
                        usernameVariable: 'REG_USER',
                        passwordVariable: 'REG_PASS')]) {
                    script {
                        // 레지스트리에서 "받아서" 올린다 (D-52).
                        //
                        // 방금 빌드한 로컬 이미지를 그대로 쓰지 않는 이유 —
                        // 그러면 레지스트리를 거치는지 확인할 수 없다. 실제
                        // 배포 서버는 빌드 머신이 아니므로 pull 말고는 방법이 없다.
                        //
                        // 배포 스택은 compose.yaml과 분리돼 있다. 개발 중인
                        // 스택을 재시작시키면 작업 중에 서비스가 끊긴다.
                        sh '''
                            echo "$REG_PASS" | docker login "$REGISTRY_HOST" -u "$REG_USER" --password-stdin
                        '''
                        try {
                            // 커밋 SHA로 고정해서 올린다. latest로 올리면
                            // 어느 커밋이 떠 있는지 나중에 알 수 없다.
                            sh """
                                DEPLOY_TAG=${env.GIT_SHORT} \
                                docker compose -f compose.deploy.yaml pull
                                DEPLOY_TAG=${env.GIT_SHORT} \
                                docker compose -f compose.deploy.yaml up -d
                            """
                        } finally {
                            sh 'docker logout "$REGISTRY_HOST" || true'
                        }

                        // 뜬 것으로 끝내지 않고 healthy가 될 때까지 본다.
                        // "컨테이너가 실행 중"과 "서비스가 응답한다"는 다르다 —
                        // 이 프로젝트에서 여러 번 확인한 구분이다.
                        sh '''
                            echo "헬스체크 대기..."
                            for i in $(seq 1 40); do
                                UNHEALTHY=$(docker ps --filter "name=lxp-deploy-" \
                                    --filter "health=unhealthy" --format '{{.Names}}' | wc -l)
                                STARTING=$(docker ps --filter "name=lxp-deploy-" \
                                    --filter "health=starting" --format '{{.Names}}' | wc -l)
                                HEALTHY=$(docker ps --filter "name=lxp-deploy-" \
                                    --filter "health=healthy" --format '{{.Names}}' | wc -l)
                                echo "  [$i] healthy=$HEALTHY starting=$STARTING unhealthy=$UNHEALTHY"
                                if [ "$STARTING" -eq 0 ] && [ "$UNHEALTHY" -eq 0 ] && [ "$HEALTHY" -gt 0 ]; then
                                    echo "배포 완료: $HEALTHY개 healthy"
                                    exit 0
                                fi
                                sleep 15
                            done
                            echo "배포한 컨테이너가 healthy가 되지 않았다"
                            docker ps --filter "name=lxp-deploy-" \
                                --format '{{.Names}}\t{{.Status}}'
                            exit 1
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            echo "성공: ${env.CHANGED_SERVICES ?: '변경 없음'}"
        }
        failure {
            echo "실패: ${env.JOB_NAME} #${env.BUILD_NUMBER}"
        }
    }
}
