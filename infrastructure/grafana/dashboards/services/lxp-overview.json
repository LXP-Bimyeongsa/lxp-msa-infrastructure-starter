{
  "uid": "lxp-overview",
  "title": "LXP MSA — 서비스 개요",
  "tags": [
    "lxp"
  ],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "서비스 상태",
      "description": "Prometheus 스크레이프 기준. 0이면 D-54의 '서비스 다운' 알림이 2분 뒤 발동한다.",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "lxp-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"lxp-docker-services\"}",
          "legendFormat": "{{instance}}",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "lxp-prometheus"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "서킷브레이커",
      "description": "subscription → member gRPC (D-17). open이면 fail-closed로 503을 낸다(D-18).",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "lxp-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "resilience4j_circuitbreaker_state{state=\"open\"}",
          "legendFormat": "{{name}}",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "lxp-prometheus"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "CLOSED",
                  "color": "green",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "OPEN",
                  "color": "red",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "id": 2
    },
    {
      "type": "timeseries",
      "title": "요청 처리량 (req/s)",
      "description": "서비스별 초당 요청 수. k6 부하 테스트 중에는 여기가 치솟는다.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "lxp-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (instance) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "lxp-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "id": 3
    },
    {
      "type": "timeseries",
      "title": "응답 지연 p95",
      "description": "인증 경로는 JWKS 검증 + introspection(D-35) + 서비스 토큰 발급(D-33)을 포함한다. k6 실측 p95는 9.25ms였다.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "lxp-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, instance) (rate(http_server_requests_seconds_bucket[1m])))",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "lxp-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "응답 상태 분포",
      "description": "4xx는 정상적인 거절(401 위장 차단 등)일 수 있다. 5xx가 늘면 D-54의 알림이 3분 뒤 발동한다.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "lxp-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{status}}",
          "datasource": {
            "type": "prometheus",
            "uid": "lxp-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean"
          ]
        }
      },
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "JVM 힙 사용량",
      "description": "배포 인스턴스는 -Xmx256m로 제한돼 있다(D-52).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "lxp-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (instance) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "lxp-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "id": 6
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "로그 발생량 (서비스별)",
      "description": "D-64 이후 service가 라벨이라 파일 경로가 아니라 서비스 이름으로 묶인다. 평소 INFO에서는 요청마다 찍지 않으므로 낮게 유지되는 것이 정상이고, 치솟으면 예외가 반복되고 있다는 뜻이다.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "datasource": {
        "type": "loki",
        "uid": "lxp-loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (count_over_time({job=\"lxp-services\"}[1m]))",
          "legendFormat": "{{service}}",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "lxp-loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum"
          ]
        }
      }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "오류 로그 (ERROR · WARN)",
      "description": "정규식이 아니라 level 라벨로 거른다 (D-64). 평문을 |~ \" (ERROR|WARN) \" 로 긁던 시절에는 형식이 조금만 달라져도 조용히 0건이 됐다 — 필터가 틀렸는데 \"오류가 없다\"로 보이는 것이 가장 나쁘다.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "datasource": {
        "type": "loki",
        "uid": "lxp-loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"lxp-services\", level=~\"ERROR|WARN\"} | json | line_format \"{{.service_name}} · {{.log_logger}} — {{.message}}\"",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "lxp-loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "prettifyLogMessage": false
      },
      "expr": "{job=\"lxp-services\"} |~ ` (ERROR|WARN) `"
    },
    {
      "id": 9,
      "type": "logs",
      "title": "전체 로그 (최신순)",
      "description": "저장된 원문은 ECS JSON이다. 여기서는 읽기 좋게 한 줄로 접어 보여주고, 줄을 펼치면 traceId를 포함한 모든 필드가 나온다. 그 traceId로 Zipkin에서 같은 요청의 전체 경로를 볼 수 있다.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "datasource": {
        "type": "loki",
        "uid": "lxp-loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"lxp-services\"} | json | line_format \"{{.service_name}} · {{.log_logger}} — {{.message}}\"",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "lxp-loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "prettifyLogMessage": false
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "로그 레벨 분포",
      "description": "level이 라벨이 되어 비로소 그릴 수 있게 된 그림이다. WARN·ERROR가 평소 수준을 벗어나는 순간을 지표(위쪽 패널)와 같은 시간축에서 대조할 수 있다.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 39
      },
      "datasource": {
        "type": "loki",
        "uid": "lxp-loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (level) (count_over_time({job=\"lxp-services\"}[1m]))",
          "legendFormat": "{{level}}",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "lxp-loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "ERROR"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "WARN"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "INFO"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum"
          ]
        }
      }
    }
  ],
  "description": "LXP MSA 운영 개요. 서비스 상태·서킷·처리량·지연·오류·힙을 한 화면에서 본다."
}