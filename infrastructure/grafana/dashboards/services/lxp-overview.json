{
  "uid": "lxp-overview",
  "title": "LXP MSA — 서비스 개요",
  "tags": [
    "lxp"
  ],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "서비스 상태",
      "description": "Prometheus 스크레이프 기준. 0이면 D-54의 '서비스 다운' 알림이 2분 뒤 발동한다.",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "lxp-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"lxp-docker-services\"}",
          "legendFormat": "{{instance}}",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "lxp-prometheus"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "서킷브레이커",
      "description": "subscription → member gRPC (D-17). open이면 fail-closed로 503을 낸다(D-18).",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "lxp-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "resilience4j_circuitbreaker_state{state=\"open\"}",
          "legendFormat": "{{name}}",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "lxp-prometheus"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "CLOSED",
                  "color": "green",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "OPEN",
                  "color": "red",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "id": 2
    },
    {
      "type": "timeseries",
      "title": "요청 처리량 (req/s)",
      "description": "서비스별 초당 요청 수. k6 부하 테스트 중에는 여기가 치솟는다.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "lxp-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (instance) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "lxp-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "id": 3
    },
    {
      "type": "timeseries",
      "title": "응답 지연 p95",
      "description": "인증 경로는 JWKS 검증 + introspection(D-35) + 서비스 토큰 발급(D-33)을 포함한다. k6 실측 p95는 9.25ms였다.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "lxp-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, instance) (rate(http_server_requests_seconds_bucket[1m])))",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "lxp-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "응답 상태 분포",
      "description": "4xx는 정상적인 거절(401 위장 차단 등)일 수 있다. 5xx가 늘면 D-54의 알림이 3분 뒤 발동한다.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "lxp-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{status}}",
          "datasource": {
            "type": "prometheus",
            "uid": "lxp-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean"
          ]
        }
      },
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "JVM 힙 사용량",
      "description": "배포 인스턴스는 -Xmx256m로 제한돼 있다(D-52).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "lxp-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (instance) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "lxp-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "id": 6
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "로그 발생량 (서비스별)",
      "description": "서비스가 실제로 로그를 남기는 양. 평소 INFO 레벨에서는 요청마다 찍지 않으므로 낮게 유지되는 것이 정상이다. 갑자기 치솟으면 예외가 반복되고 있다는 뜻이다.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "datasource": {
        "type": "loki",
        "uid": "lxp-loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (filename) (count_over_time({job=\"lxp-services\"}[1m]))",
          "legendFormat": "{{filename}}",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "lxp-loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum"
          ]
        }
      }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "오류 로그 (ERROR · WARN)",
      "description": "D-47 이후 예외 원인(cause)과 스택트레이스가 남는다. 그 전에는 \"실패했다\"만 있고 \"왜\"가 없었다.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "datasource": {
        "type": "loki",
        "uid": "lxp-loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"lxp-services\"} |~ ` (ERROR|WARN) `",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "lxp-loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "prettifyLogMessage": false
      },
      "expr": "{job=\"lxp-services\"} |~ ` (ERROR|WARN) `"
    },
    {
      "id": 9,
      "type": "logs",
      "title": "전체 로그 (최신순)",
      "description": "로그 줄에 [traceId,spanId]가 붙어 있다. 그 traceId로 Zipkin에서 같은 요청의 전체 경로를 볼 수 있다.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "datasource": {
        "type": "loki",
        "uid": "lxp-loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"lxp-services\"}",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "lxp-loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "prettifyLogMessage": false
      }
    }
  ],
  "description": "LXP MSA 운영 개요. 서비스 상태·서킷·처리량·지연·오류·힙을 한 화면에서 본다."
}