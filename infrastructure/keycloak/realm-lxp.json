{
  "realm": "lxp",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 300,

  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"validations\":{\"length\":{\"min\":3,\"max\":255}},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\"]},\"multivalued\":false},{\"name\":\"email\",\"displayName\":\"${email}\",\"validations\":{\"email\":{}},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\"]},\"multivalued\":false},{\"name\":\"member_id\",\"displayName\":\"Internal member id\",\"permissions\":{\"view\":[\"admin\"],\"edit\":[\"admin\"]},\"multivalued\":false}],\"groups\":[]}"
          ]
        }
      }
    ]
  },

  "requiredActions": [
    {
      "alias": "VERIFY_PROFILE",
      "name": "Verify Profile",
      "providerId": "VERIFY_PROFILE",
      "enabled": false,
      "defaultAction": false,
      "priority": 90,
      "config": {}
    }
  ],

  "clients": [
    {
      "clientId": "lxp-web",
      "name": "LXP Web Client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "member-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "member_id",
            "claim.name": "member_id",
            "jsonType.label": "long",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "lxp-gateway",
      "name": "lxp-gateway (서비스 간 호출 증명용, D-33)",
      "enabled": true,
      "publicClient": false,
      "secret": "lxp-gateway-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "internal-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "lxp-internal",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "subscription-service",
      "name": "subscription-service (member gRPC 호출용, D-34)",
      "enabled": true,
      "publicClient": false,
      "secret": "subscription-service-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "internal-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "lxp-internal",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "member-service",
      "name": "member-service (Admin API 호출용)",
      "enabled": true,
      "publicClient": false,
      "secret": "member-service-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect"
    }
  ],

  "users": [
    {
      "username": "service-account-member-service",
      "enabled": true,
      "serviceAccountClientId": "member-service",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users"]
      }
    }
  ]
}
