{
  "priority": 10,
  "request": {
    "method": "POST",
    "urlPath": "/v1/payments/cancel"
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "status": "CANCELED",
      "canceledAt": "{{now format='yyyy-MM-dd HH:mm:ss'}}"
    },
    "transformers": ["response-template"]
  }
}
