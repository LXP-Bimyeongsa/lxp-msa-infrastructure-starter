{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/v1/payments",
    "bodyPatterns": [
      { "matchesJsonPath": "$[?(@.amount == 1006)]" }
    ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "fixedDelayMilliseconds": 10000,
    "jsonBody": {
      "transactionId": "{{randomValue type='UUID'}}",
      "status": "APPROVED",
      "approvedAt": "{{now format='yyyy-MM-dd HH:mm:ss'}}"
    },
    "transformers": ["response-template"]
  }
}
